package com.mphasis.secondspringapp.service;

import org.springframework.beans.factory.annotation.Qualifier;
import org.springframework.stereotype.Component;

@Component
public class UserServiceExercise3 {

    private final NotificationService notificationService;

    // ✅ @Qualifier tells Spring which implementation to use
    public UserServiceExercise3(
            @Qualifier("emailService") NotificationService notificationService) {
        this.notificationService = notificationService;
    }

    public void notifyUser() {
        notificationService.sendNotification(
                "Welcome to our application",
                "user@example.com");
    }
}