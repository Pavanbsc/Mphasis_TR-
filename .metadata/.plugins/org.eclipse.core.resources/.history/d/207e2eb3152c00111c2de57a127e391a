package com.mphasis.firstspringapp;

import org.springframework.context.support.ClassPathXmlApplicationContext;
import com.mphasis.firstspringapp.service.GreetService;
import com.mphasis.firstspringapp.service.OrderService;

public class MainServerApp {

    public static void main(String[] args) {

        ClassPathXmlApplicationContext context =
                new ClassPathXmlApplicationContext("spring-config.xml");

       
        GreetService greetService =
                context.getBean("greetService", GreetService.class);
        greetService.greet();

        System.out.println("++++++++++++++++++++++++++++++++++++++");

       
        OrderService orderService =
                context.getBean("orderService", OrderService.class);
        orderService.placeOrder();

       
        context.close();
    }
}
